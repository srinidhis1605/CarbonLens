# Database Core Infrastructure Connections
# Local MySQL example:
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=your_database_password_here
# DB_NAME=carbonlens_db
# DB_PORT=3306
# DB_SSL=false

# Aiven MySQL example:
DB_HOST=mysql-3c748675-carbolens.k.aivencloud.com
DB_USER=avnadmin
DB_PASSWORD=your_aiven_password_here
DB_NAME=defaultdb
DB_PORT=25117
DB_SSL=true
# Download CA cert from Aiven -> save as backend/certs/ca.pem
# Or paste full PEM into DB_SSL_CA_PEM (use \n for line breaks)
# DB_SSL_CA=./certs/ca.pem
# DB_SSL_CA_PEM=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

PORT=5000
FRONTEND_ORIGIN=http://localhost:3000,https://carbolens.netlify.app

# Authentication Authorization Tokens
JWT_SECRET=your_super_secret_jwt_signing_key_here
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_here

# Day 9 - Google Free AI Configuration (OpenAI Compatible)
AI_API_KEY=your_free_gemini_api_key_placeholder
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
